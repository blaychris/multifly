*~

# Android app bundles and APKs
*.aab
*.apk

# Logs
*.log

# Ignore all build intermediates
**/build/
**/intermediates/
**/outputs/
**/tmp/

# Ignore all gradle wrappers and caches
.gradle/
**/gradle/
**/gradlew
**/gradlew.bat

# Ignore all node_modules (if any)
node_modules/


#large folders
.godot
