# Godot build and export folders
.export/
.export-debug/
.export-release/

# Godot import files
.import/

# Godot temporary files
*.tmp
*.temp

# Mono build artifacts
.mono/
*.csproj.user
*.sln.docstates

# Android folder (ignore all)
android/
.godot/

# Large binary assets (optional, if not needed in repo)
*.kra
*.psd
*.blend
*.wav
*.mp3
*.jpg
*.jpeg
*.import

# User/editor settings
*.cfg
*.import
*.imported
*.md5
*.ctex
*.uid

# VS Code settings
.vscode/

# Optional: VS Code workspace/user settings (uncomment if not sharing these)
# .vscode/settings.json
# .vscode/launch.json

# JetBrains IDEs (optional)
.idea/

# macOS system files
.AppleDouble
.Spotlight-V100
.Trashes
._*
.fseventsd

# Windows system files
ehthumbs.db
desktop.ini

# Linux/KDE system files
.directory

# Editor swap/lock files
*.swp
*.swo
.nfs*

# Python virtual environments (if used)
venv/
.venv/

# Optional: Godot export presets (if not sharing)
# export_presets.cfg

# OS generated files
.DS_Store
Thumbs.db

# Godot hidden folder (cache, build, and temp files)
.godot/editor/
.godot/exported/
.godot/imported/
.godot/mono/
.godot/shader_cache/
.godot/uid_cache.bin
.godot/global_script_class_cache.cfg
.godot/scene_groups_cache.cfg
.godot/export_credentials.cfg

# Backup files
*~

# Android app bundles and APKs
*.aab
*.apk

# Logs
*.log

# Ignore all build intermediates
**/build/
**/intermediates/
**/outputs/
**/tmp/

# Ignore all gradle wrappers and caches
.gradle/
**/gradle/
**/gradlew
**/gradlew.bat

# Ignore all node_modules (if any)
node_modules/


#large folders
.godot
